<!DOCTYPE html>
<html>
<head>
<title>CUET Security Alert</title>
<style>
body {
  margin: 0;
  background: black;
  color: red;
  font-family: monospace;
  text-align: center;
  overflow: hidden;
}
h1 {
  font-size: 45px;
  animation: blink 0.7s infinite;
}
#big {
  font-size: 70px;
  margin-top: 20px;
  animation: blink 0.4s infinite;
}
#apps {
  font-size: 35px;
  color: yellow;
  margin-top: 20px;
}
#text {
  margin-top: 20px;
  font-size: 22px;
  color: lime;
}
#timer {
  font-size: 80px;
  margin-top: 20px;
}
@keyframes blink {
  0% { opacity: 1; }
  50% { opacity: 0.1; }
  100% { opacity: 1; }
}
</style>
</head>
<body>

<h1>⚠️ CUET SECURITY ALERT ⚠️</h1>
<div id="big">YOUR MOBILE IS HACKED</div>
<div id="apps">INSTAGRAM & WHATSAPP ACCESSED</div>
<div id="text">Initializing breach...</div>
<div id="timer">60</div>

<script>
let text = document.getElementById("text");

let steps = [
"Connecting to CUET secure server...",
"Tracking device...",
"Accessing social media data...",
"Instagram data extracted...",
"WhatsApp messages copied...",
"Finalizing process..."
];

let i = 0;

function type(msg, cb) {
  let j = 0;
  let inter = setInterval(() => {
    text.innerHTML = msg.substring(0, j);
    j++;
    if (j > msg.length) {
      clearInterval(inter);
      setTimeout(cb, 800);
    }
  }, 40);
}

function run() {
  if (i < steps.length) {
    type(steps[i], () => {
      i++;
      run();
    });
  } else {
    startTimer();
  }
}

function startTimer() {
  let t = 60;
  let timer = document.getElementById("timer");

  let c = setInterval(() => {
    timer.innerHTML = t;
    t--;

    // vibration
    if (navigator.vibrate) {
      navigator.vibrate([300,100,300]);
    }

    if (t < 0) {
      clearInterval(c);
      document.body.innerHTML = `
        <h1>😂 APRIL FOOL 😂</h1>
        <p>Relax! Kuch bhi hack nahi hua 😄</p>
        <div style="color:cyan;">🔥 Created by Deep 🔥</div>
      `;
    }
  }, 1000);
}

run();

// back block
history.pushState(null, null, location.href);
window.onpopstate = function () {
  history.go(1);
};
</script>

</body>
</html>
